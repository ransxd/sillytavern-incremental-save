+/**
+ * Incrementally appends new messages to an existing chat file.
+ * Updates the header (first line) and appends new messages to the end.
+ * @param {string} chatFilePath Path to the chat file
+ * @param {object} header The updated chat header object
+ * @param {Array} newMessages Array of new message objects to append
+ * @param {number} expectedLines Expected number of lines in the file (for consistency check)
+ * @param {string} handle User handle for backup
+ * @param {string} cardName Card name for backup
+ * @param {string} backupDirectory Backup directory path
+ * @returns {Promise<{ok: boolean, error?: string, actualLines?: number}>}
+ */
+async function tryAppendChat(chatFilePath, header, newMessages, expectedLines, handle, cardName, backupDirectory) {
+    if (!fs.existsSync(chatFilePath)) {
+        return { ok: false, error: 'file_not_found' };
+    }
+
+    // Verify line count matches expectations
+    const actualLines = await countLines(chatFilePath);
+    if (actualLines !== expectedLines) {
+        console.warn(`Line count mismatch for "${chatFilePath}": expected ${expectedLines}, got ${actualLines}`);
+        return { ok: false, error: 'line_mismatch', actualLines };
+    }
+
+    // Read existing file, replace header (first line), append new messages
+    const existingData = fs.readFileSync(chatFilePath, 'utf8');
+    const firstNewline = existingData.indexOf('\n');
+    const restOfFile = firstNewline >= 0 ? existingData.substring(firstNewline) : '';
+
+    const headerLine = JSON.stringify(header);
+    const appendData = newMessages.length > 0 ? '\n' + newMessages.map(m => JSON.stringify(m)).join('\n') : '';
+    const newData = headerLine + restOfFile + appendData;
+
+    tryWriteFileSync(chatFilePath, newData);
+    getBackupFunction(handle)(backupDirectory, cardName, newData);
+
+    return { ok: true };
+}
