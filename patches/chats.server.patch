 /**
+ * Counts the number of lines in a file efficiently using streaming.
+ * @param {string} filePath Path to the file
+ * @returns {Promise<number>} Number of lines in the file
+ */
+async function countLines(filePath) {
+    return new Promise((resolve, reject) => {
+        let count = 0;
+        const stream = fs.createReadStream(filePath);
+        stream.on('data', (chunk) => {
+            for (let i = 0; i < chunk.length; i++) {
+                if (chunk[i] === 10) count++; // \n
+            }
+        });
+        stream.on('end', () => {
+            // If file is non-empty and doesn't end with \n, the last line still counts
+            resolve(count > 0 ? count + 1 : 1);
+        });
+        stream.on('error', reject);
+    });
+}
