+// Incremental save tracking
+let lastSavedChatName = null;
+let lastSavedChatLength = 0;
+let lastSavedChatHash = null;
+
+/**
+ * Computes a lightweight hash of chat messages for change detection.
+ * @param {object[]} chatArray The chat array
+ * @param {number} upToIndex Hash messages up to this index
+ * @returns {string} Hash string
+ */
+function computeChatHash(chatArray, upToIndex) {
+    let hash = '';
+    // Start from index 1: skip the first message (greeting) because Generate()
+    // calls substituteParams(chat[0].mes) which may change its length every time
+    for (let i = 1; i < upToIndex && i < chatArray.length; i++) {
+        const m = chatArray[i];
+        hash += `${(m.mes || '').length}:${m.swipe_id ?? 0},`;
+    }
+    return hash;
+}
+
+/**
+ * Checks if old messages have been modified since last save.
+ * @param {object[]} chatArray Current chat array
+ * @param {number} savedLength Number of messages at last save
+ * @returns {boolean} True if old messages changed
+ */
+function hasOldMessagesChanged(chatArray, savedLength) {
+    return computeChatHash(chatArray, savedLength) !== lastSavedChatHash;
+}
+
+/**
+ * Resets incremental save tracking state.
+ * Call this when switching chats, characters, or reloading.
+ */
+export function resetIncrementalSaveState() {
+    lastSavedChatName = null;
+    lastSavedChatLength = 0;
+    lastSavedChatHash = null;
+}
